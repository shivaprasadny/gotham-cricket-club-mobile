{
  "expo": {
    "name": "Gotham Cricket",
    "slug": "gotham-cricket-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#2b0540"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shivaprasadnyc.gothamcricketmobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shivaprasadnyc.gothamcricketmobile"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "cc31b874-cd6f-4142-93e6-519164925364"
      }
    },
    "owner": "shivaprasadnyc"
  }
}
